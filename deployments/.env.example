# =============================================================================
# Lumina Knowledge Engine - Environment Configuration
# =============================================================================

# --- Image Versions ---
# Check https://hub.docker.com/r/qdrant/qdrant/tags for the latest version
QDRANT_VERSION=v1.17.0
# Node environment: 'development' or 'production'
NODE_ENV=production

# --- Host Port Mapping ---
# These ports will be exposed on your host machine
HOST_QDRANT_REST_PORT=6333
HOST_QDRANT_GRPC_PORT=6334
HOST_BRAIN_API_PORT=8000
HOST_PORTAL_PORT=3018

# --- Database Configuration ---
# Internal hostname and port for Qdrant (used by brain-api)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# --- Brain API Service Settings ---
# Embedding model name (e.g., all-MiniLM-L6-v2, bge-small-en-v1.5)
MODEL_NAME=all-MiniLM-L6-v2
MODEL_CACHE_DIR=/app/models
LOG_LEVEL=info

# --- Portal Frontend Settings ---
# The URL where the frontend can reach the Brain API
# For local browser access, use http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Crawler Settings (Optional) ---
# Endpoint for the crawler to push data
BRAIN_INGEST_URL=http://brain-api:8000/ingest
